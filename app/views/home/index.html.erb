<%# ── Hero ──────────────────────────────────────────────────────── %>
<section class="hero shell">
  <div class="hero-head">
    <div>
      <span class="section-eyebrow">Curated pieces for every version of you</span>
      <h1 class="hero-headline">Tu próximo outfit favorito.</h1>
    </div>
    <p class="hero-sub">
      Mira lo nuevo, explora por categoría y encuentra el tuyo.
    </p>
  </div>

  <div class="reel-row">
    <div class="reel">
      <div class="reel-placeholder" style="background: linear-gradient(160deg, #e8c8d8 0%, #c87da8 100%);"></div>
      <span class="reel-tag">Lookbook</span>
      <div class="reel-label">
        <span>Pijama set rayas</span>
        <span class="arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
        </span>
      </div>
    </div>

    <div class="reel">
      <div class="reel-placeholder" style="background: linear-gradient(160deg, #f5e88a 0%, #e0c830 100%);"></div>
      <span class="reel-tag">Try-on</span>
      <div class="reel-label">
        <span>Top encaje Inés</span>
        <span class="arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
        </span>
      </div>
    </div>

    <div class="reel">
      <div class="reel-placeholder" style="background: linear-gradient(160deg, #820045 0%, #5d0031 100%);"></div>
      <span class="reel-tag">Unboxing</span>
      <div class="reel-label" style="color:#f2e651;">
        <span>Pedido naar #420</span>
        <span class="arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
        </span>
      </div>
    </div>
  </div>
</section>

<%# ── Delivery strip ──────────────────────────────────────────── %>
