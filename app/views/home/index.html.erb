<%# ── Categorías ──────────────────────────────────────────────── %>
<section class="section shell" id="cats">
  <div class="section-head">
    <div>
      <span class="section-eyebrow">Toca y filtra</span>
      <h2 class="section-title">Por categoría</h2>
    </div>
  </div>

  <div class="cats">
    <a href="#nuevos" class="cat-tile is-active">
      <div class="cat-img">✦</div>
      <span class="cat-name">Todo</span>
    </a>
    <% [
      { id: "vestidos",   name: "Vestidos"   },
      { id: "tops",       name: "Tops"       },
      { id: "sets",       name: "Sets"       },
      { id: "faldas",     name: "Faldas"     },
      { id: "pantalones", name: "Pantalones" },
      { id: "bodys",      name: "Bodys"      },
      { id: "sueteres",   name: "Suéteres"   },
      { id: "rompers",    name: "Rompers"    },
      { id: "shorts",     name: "Shorts"     },
      { id: "chaquetas",  name: "Chaquetas"  },
      { id: "descuentos", name: "Descuentos" },
    ].each do |cat| %>
      <a href="#cat-section-<%= cat[:id] %>" class="cat-tile">
        <div class="cat-img" style="background:var(--lemon-pale);"></div>
        <span class="cat-name"><%= cat[:name] %></span>
      </a>
    <% end %>
  </div>
</section>

