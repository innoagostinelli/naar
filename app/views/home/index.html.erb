<%# ── Hero ──────────────────────────────────────────────────────── %>
<section class="hero shell">
  <div class="hero-head">
    <div>
      <span class="section-eyebrow">Curated pieces for every version of you</span>
      <h1 class="hero-headline">Tu próximo outfit favorito.</h1>
    </div>
    <p class="hero-sub">
      Mira lo nuevo, explora por categoría y encuentra el tuyo.
    </p>
  </div>

  <div class="reel-row">
    <% @reels.each do |reel| %>
      <div class="reel">
        <% if reel.video.attached? %>
          <video class="reel-placeholder" src="<%= url_for(reel.video) %>" autoplay muted loop playsinline></video>
        <% else %>
          <div class="reel-placeholder" style="background: linear-gradient(160deg, #e8c8d8 0%, #c87da8 100%);"></div>
        <% end %>
        <span class="reel-tag"><%= reel.tag %></span>
        <div class="reel-label">
          <span><%= reel.label %></span>
          <span class="arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
          </span>
        </div>
      </div>
    <% end %>
  </div>
</section>

<%# ── Delivery strip ──────────────────────────────────────────── %>
<div class="shell">
  <div class="delivery-strip">
    <div class="delivery-info">
      <div class="ic">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8zM5.5 21a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zM18.5 21a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z"/>
        </svg>
      </div>
      <div>
        <h3>Delivery a toda Venezuela 🇻🇪</h3>
        <p>Mismo día en Lechería · Envíos nacionales en 24 h</p>
      </div>
    </div>
    <a href="https://wa.me/message/HBW5LBXEBZ7MH1" target="_blank" rel="noopener" class="delivery-cta">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      Coordinar mi envío
    </a>
  </div>
</div>

<%# ── Categorías + Catálogo (filtro dinámico) ─────────────────── %>
<div data-controller="category-filter">

<section class="section shell" id="cats">
  <div class="section-head">
    <div>
      <span class="section-eyebrow">Toca y filtra</span>
      <h2 class="section-title">Por categoría</h2>
    </div>
  </div>

  <div class="cats">
    <button type="button" class="cat-tile is-active"
            data-category-filter-target="tile"
            data-slug="all"
            data-action="click->category-filter#filter">
      <div class="cat-img">✦</div>
      <span class="cat-name">Todo</span>
    </button>
    <% @categories.each do |cat| %>
      <button type="button" class="cat-tile"
              data-category-filter-target="tile"
              data-slug="<%= cat.slug %>"
              data-action="click->category-filter#filter">
        <% if cat.image.attached? %>
          <div class="cat-img"><%= image_tag cat.image.variant(resize_to_fill: [ 300, 300 ]), alt: cat.name %></div>
        <% else %>
          <div class="cat-img" style="background:var(--lemon-pale);"></div>
        <% end %>
        <span class="cat-name"><%= cat.name %></span>
      </button>
    <% end %>
  </div>
</section>

<%# ── Nuevos ingresos ─────────────────────────────────────────── %>
<section class="section shell" id="nuevos"
         data-category-filter-target="section"
         data-category="nuevos">
  <div class="section-head">
    <div>
      <span class="section-eyebrow"><%= @homepage_setting.new_arrivals_eyebrow %></span>
      <h2 class="section-title"><%= @homepage_setting.new_arrivals_title %></h2>
    </div>
    <button class="see-all" type="button">
      Ver más
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>

  <div class="products">
    <% @nuevos.each do |product| %>
      <%= render "shared/product_card", product: product %>
    <% end %>
  </div>
</section>

<%# ── Catálogo por categoría ──────────────────────────────────── %>
<% preview_count = 4 %>
<% @categories.each do |cat| %>
  <% items = cat.products.active.order(:position).includes(:images, :variants) %>
  <% next if items.empty? %>

  <section class="section shell" id="cat-section-<%= cat.slug %>"
           data-category-filter-target="section"
           data-category="<%= cat.slug %>"
           data-controller="<%= "see-more" if items.size > preview_count %>">
    <div class="section-head">
      <div>
        <h2 class="section-title"><%= cat.name %></h2>
      </div>
      <% if items.size > preview_count %>
        <button class="see-all" type="button" data-see-more-target="button" data-action="click->see-more#expand">
          Ver todo
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
        </button>
      <% end %>
    </div>
    <div class="products">
      <% items.each_with_index do |product, i| %>
        <% if i < preview_count %>
          <%= render "shared/product_card", product: product %>
        <% else %>
          <div class="grid-extra-item" data-see-more-target="extra"><%= render "shared/product_card", product: product %></div>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

</div><%# /category-filter %>

<%# ── FAQ ────────────────────────────────────────────────────── %>
<section class="section shell" id="faqs" style="padding-bottom:56px;">
  <div class="section-head">
    <div>
      <span class="section-eyebrow">Resolvemos tus dudas</span>
      <h2 class="section-title">Preguntas frecuentes</h2>
    </div>
    <a href="https://wa.me/message/HBW5LBXEBZ7MH1" target="_blank" rel="noopener" class="see-all">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      Pregúntanos
    </a>
  </div>

  <div class="faqs">
    <% @faqs.each_with_index do |faq, i| %>
      <div class="faq" id="faq-<%= i %>">
        <button class="faq-q" onclick="this.closest('.faq').classList.toggle('is-open')" type="button">
          <span><%= faq.question %></span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="faq-a">
          <p><%= faq.answer %></p>
        </div>
      </div>
    <% end %>
  </div>
</section>
