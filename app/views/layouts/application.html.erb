<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for(:title) || "Naar — Tienda online" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Naar">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>

    <%# Announcement bar %>
    <div class="ann">
      ✦ <strong>Envíos a toda Venezuela</strong> 🇻🇪
    </div>

    <%# Header %>
    <header class="site-header">
      <div class="shell header-row">

        <nav class="site-nav desktop" aria-label="Categorías">
          <%= link_to "Inicio", root_path, class: "active" %>
          <%= link_to "Nuevos ingresos", "#nuevos" %>
          <%= link_to "Categorías", "#cats" %>
          <%= link_to "FAQs", "#faqs" %>
        </nav>

        <div class="brand-logo">
          <%= link_to root_path do %>
            <%= image_tag "logo-naar.png", alt: "Naar", height: 56 %>
          <% end %>
        </div>

        <div class="header-actions">
          <button class="icon-btn" aria-label="Buscar">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
            </svg>
          </button>

          <button class="icon-btn" aria-label="Favoritos">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </button>

          <button class="icon-btn" aria-label="Carrito">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0"/>
            </svg>
            <span class="cart-dot">0</span>
          </button>

          <button class="icon-btn menu-toggle" aria-label="Menú">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>

      </div>
    </header>

    <main>
      <%= yield %>
    </main>

    <%# Footer %>
    <footer class="site-footer">
      <div class="shell">
        <div class="footer-grid">

          <div>
            <div class="footer-brand">
              <%= image_tag "logo-naar-blanco.png", alt: "naar" %>
            </div>
            <p style="font-size:14px; margin-top:14px; opacity:.8; max-width:260px;">
              Tu lugar para encontrar outfits que sí vas a repetir 🤍
            </p>
            <div class="socials">
              <a href="https://wa.me/message/HBW5LBXEBZ7MH1" target="_blank" rel="noopener" aria-label="WhatsApp">
