<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <title><%= content_for?(:page_title) ? "#{yield(:page_title)} · Admin naar" : "Admin · naar" %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/css/tabler.min.css">
  <%= stylesheet_link_tag "admin", media: "all" %>
  <%= csrf_meta_tags %>
  <%= javascript_importmap_tags %>
</head>
<body class="antialiased">
<div class="wrapper">

  <%# ── Sidebar ──────────────────────────────────────────────── %>
  <aside class="navbar navbar-vertical navbar-expand-lg naar-sidebar">
    <div class="container-fluid">
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu">
        <span class="navbar-toggler-icon"></span>
      </button>

      <a href="<%= admin_root_path %>" class="navbar-brand naar-brand">
        <span class="brand-wordmark">naar</span>
        <span class="brand-tag">panel de gestión</span>
      </a>

      <div class="collapse navbar-collapse" id="sidebar-menu">
        <ul class="navbar-nav pt-lg-3">

          <li class="nav-item">
            <%= link_to admin_root_path, class: "nav-link #{controller_name == 'dashboard' ? 'active' : ''}" do %>
              <span class="nav-link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              </span>
              <span class="nav-link-title">Dashboard</span>
            <% end %>
          </li>

          <li class="nav-item mt-2">
            <span class="nav-link-header">Catálogo</span>
          </li>

          <li class="nav-item">
            <%= link_to admin_products_path, class: "nav-link #{controller_name == 'products' ? 'active' : ''}" do %>
              <span class="nav-link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              </span>
              <span class="nav-link-title">Productos</span>
            <% end %>
          </li>

          <li class="nav-item">
            <%= link_to admin_categories_path, class: "nav-link #{controller_name == 'categories' ? 'active' : ''}" do %>
              <span class="nav-link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
              </span>
              <span class="nav-link-title">Categorías</span>
            <% end %>
          </li>

          <li class="nav-item mt-2">
            <span class="nav-link-header">Ventas</span>
          </li>

          <li class="nav-item">
            <%= link_to admin_orders_path, class: "nav-link #{controller_name == 'orders' ? 'active' : ''}" do %>
              <span class="nav-link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              </span>
              <span class="nav-link-title">Pedidos</span>
            <% end %>
          </li>

          <li class="nav-item mt-2">
            <span class="nav-link-header">Contenido</span>
          </li>

          <li class="nav-item">
            <%= link_to admin_faqs_path, class: "nav-link #{controller_name == 'faqs' ? 'active' : ''}" do %>
              <span class="nav-link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </span>
              <span class="nav-link-title">FAQs</span>
            <% end %>
          </li>

          <li class="nav-item">
            <%= link_to admin_reels_path, class: "nav-link #{controller_name == 'reels' ? 'active' : ''}" do %>
              <span class="nav-link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
              </span>
              <span class="nav-link-title">Reels</span>
            <% end %>
          </li>

          <li class="nav-item">
            <%= link_to edit_admin_homepage_setting_path, class: "nav-link #{controller_name == 'homepage_settings' ? 'active' : ''}" do %>
              <span class="nav-link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/></svg>
              </span>
              <span class="nav-link-title">Textos de inicio</span>
            <% end %>
          </li>

        </ul>

        <div class="mt-auto pt-3 pb-2 border-top">
          <%= link_to root_path, target: "_blank", rel: "noopener", class: "nav-link text-muted" do %>
            <span class="nav-link-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </span>
            <span class="nav-link-title">Ver tienda</span>
          <% end %>
        </div>
      </div>
    </div>
  </aside>

  <%# ── Page wrapper ─────────────────────────────────────────── %>
  <div class="page-wrapper">

    <div class="page-header d-print-none">
      <div class="container-xl">
        <div class="row g-2 align-items-center">
          <div class="col">
            <h2 class="page-title">
              <%= content_for?(:page_title) ? yield(:page_title) : "Admin" %>
            </h2>
          </div>
          <div class="col-auto ms-auto">
            <%= yield(:topbar_actions) if content_for?(:topbar_actions) %>
          </div>
        </div>
      </div>
    </div>

    <div class="page-body">
      <div class="container-xl">

        <% flash.each do |type, msg| %>
          <div class="alert alert-<%= type == 'notice' ? 'success' : 'danger' %> alert-dismissible mb-3" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% end %>

        <%= yield %>

      </div>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta17/dist/js/tabler.min.js"></script>
</body>
</html>
