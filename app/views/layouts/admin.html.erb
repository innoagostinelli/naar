<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <title>Admin · naar</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "admin", media: "all" %>
  <%= csrf_meta_tags %>
</head>
<body class="admin-body">

  <aside class="admin-sidebar">
    <div class="admin-sidebar-brand">
      <span class="brand-name">naar</span>
      <span class="brand-sub">Panel de gestión</span>
    </div>

    <nav class="admin-nav">
      <span class="nav-section">General</span>
      <%= link_to admin_root_path, class: "#{controller_name == 'dashboard' ? 'active' : ''}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Dashboard
      <% end %>

      <span class="nav-section">Catálogo</span>
      <%= link_to "Productos", admin_products_path, class: "#{controller_name == 'products' ? 'active' : ''}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        Productos
      <% end %>
      <%= link_to admin_categories_path, class: "#{controller_name == 'categories' ? 'active' : ''}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        Categorías
      <% end %>

      <span class="nav-section">Contenido</span>
      <%= link_to admin_faqs_path, class: "#{controller_name == 'faqs' ? 'active' : ''}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        FAQs
      <% end %>
      <%= link_to admin_reels_path, class: "#{controller_name == 'reels' ? 'active' : ''}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        Reels
      <% end %>
    </nav>

    <div class="admin-sidebar-footer">
      <%= link_to root_path, target: "_blank", rel: "noopener" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        Ver tienda
      <% end %>
    </div>
  </aside>

  <div class="admin-main">
    <header class="admin-topbar">
      <h1><%= content_for?(:page_title) ? yield(:page_title) : "Admin" %></h1>
      <div class="admin-actions">
        <%= yield(:topbar_actions) if content_for?(:topbar_actions) %>
      </div>
    </header>

    <% flash.each do |type, msg| %>
      <div class="admin-flash <%= type %>"><%= msg %></div>
    <% end %>

    <main class="admin-content">
      <%= yield %>
    </main>
  </div>

</body>
</html>
