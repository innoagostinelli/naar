<%= form_with model: [:admin, reel], class: "admin-form" do |f| %>
  <% if reel.errors.any? %>
    <div class="alert alert-danger mb-3">
      <ul class="mb-0">
        <% reel.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-3">
      <%= f.label :tag, "Tag", class: "form-label" %>
      <%= f.select :tag, %w[Lookbook Try-on Unboxing Outfit Behind], { prompt: "Seleccionar..." }, { class: "form-select" } %>
    </div>
    <div class="col-md-5">
      <%= f.label :label, "Label", class: "form-label" %>
      <%= f.text_field :label, class: "form-control", placeholder: "Pijama set rayas" %>
    </div>
    <div class="col-md-2">
      <%= f.label :position, "Posición", class: "form-label" %>
      <%= f.number_field :position, class: "form-control" %>
    </div>
  </div>

  <div class="mt-4 d-flex gap-2">
    <%= f.submit reel.new_record? ? "Crear reel" : "Guardar cambios", class: "btn-admin-primary" %>
    <%= link_to "Cancelar", admin_reels_path, class: "btn-admin-ghost" %>
  </div>
<% end %>
