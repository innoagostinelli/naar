<%= form_with model: [:admin, reel] do |f| %>
  <div class="card">
    <div class="card-header"><h3 class="card-title">Datos del reel</h3></div>
    <div class="card-body">
      <% if reel.errors.any? %>
        <div class="alert alert-danger mb-4">
          <ul class="mb-0">
            <% reel.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <div class="row g-3">
        <div class="col-md-3">
          <%= f.label :tag, "Tipo", class: "form-label" %>
          <%= f.select :tag, %w[Lookbook Try-on Unboxing Outfit Behind],
                { prompt: "Seleccionar..." }, { class: "form-select" } %>
        </div>
        <div class="col-md-5">
          <%= f.label :label, "Descripción", class: "form-label" %>
          <%= f.text_field :label, class: "form-control", placeholder: "Pijama set rayas" %>
        </div>
        <div class="col-md-2">
          <%= f.label :position, "Posición", class: "form-label" %>
          <%= f.number_field :position, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-3">
    <%= f.submit reel.new_record? ? "Crear reel" : "Guardar cambios", class: "btn btn-naar" %>
    <%= link_to "Cancelar", admin_reels_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
