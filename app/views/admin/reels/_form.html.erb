<%= form_with model: [:admin, reel], multipart: true, data: { controller: "direct-upload" } do |f| %>
  <div class="card">
    <div class="card-header"><h3 class="card-title">Datos del reel</h3></div>
    <div class="card-body">
      <% if reel.errors.any? %>
        <div class="alert alert-danger mb-4">
          <ul class="mb-0">
            <% reel.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <% if reel.video.attached? %>
        <div class="mb-3">
          <video src="<%= url_for(reel.video) %>" style="max-width:200px; border-radius:8px;" controls muted></video>
        </div>
      <% end %>

      <div class="row g-3">
        <div class="col-md-3">
          <%= f.label :tag, "Tipo", class: "form-label" %>
          <%= f.select :tag, %w[Lookbook Try-on Unboxing Outfit Behind],
                { prompt: "Seleccionar..." }, { class: "form-select" } %>
        </div>
        <div class="col-md-5">
          <%= f.label :label, "Descripción", class: "form-label" %>
          <%= f.text_field :label, class: "form-control", placeholder: "Pijama set rayas" %>
        </div>
        <div class="col-md-2">
          <%= f.label :position, "Posición", class: "form-label" %>
          <%= f.number_field :position, class: "form-control" %>
        </div>
        <div class="col-md-6">
          <%= f.label :video, "Video", class: "form-label" %>
          <%= f.file_field :video, class: "form-control", accept: "video/*", direct_upload: true,
                data: { direct_upload_target: "input" } %>
          <div class="progress mt-2" style="display:none; height:6px;" data-direct-upload-target="progressWrap">
            <div class="progress-bar" role="progressbar" style="width:0%" data-direct-upload-target="progressBar"></div>
          </div>
          <div class="form-text" data-direct-upload-target="status">
            <%= reel.video.attached? ? "Dejar vacío para mantener el video actual." : "" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-3">
    <%= f.submit reel.new_record? ? "Crear reel" : "Guardar cambios", class: "btn btn-naar",
          data: { direct_upload_target: "submit" } %>
    <%= link_to "Cancelar", admin_reels_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
