<% content_for :page_title, "Reels" %>
<% content_for :topbar_actions do %>
  <%= link_to "Nuevo reel", new_admin_reel_path, class: "btn-admin-primary" %>
<% end %>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Pos.</th>
        <th>Tag</th>
        <th>Label</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @reels.each do |reel| %>
        <tr>
          <td><%= reel.position %></td>
          <td><span class="badge-flag flag-nuevo"><%= reel.tag %></span></td>
          <td><%= reel.label %></td>
          <td>
            <div class="admin-actions">
              <%= link_to "Editar", edit_admin_reel_path(reel), class: "btn-admin-ghost" %>
              <%= button_to "Eliminar", admin_reel_path(reel),
                    method: :delete,
                    form: { data: { turbo_confirm: "¿Eliminar reel #{reel.label}?" } },
                    class: "btn-admin-danger" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
