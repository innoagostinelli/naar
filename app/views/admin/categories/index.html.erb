<% content_for :page_title, "Categorías" %>
<% content_for :topbar_actions do %>
  <%= link_to "Nueva categoría", new_admin_category_path, class: "btn-admin-primary" %>
<% end %>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Slug</th>
        <th>Posición</th>
        <th>Productos activos</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @categories.each do |cat| %>
        <tr>
          <td><strong><%= cat.name %></strong></td>
          <td><code><%= cat.slug %></code></td>
          <td><%= cat.position %></td>
          <td><%= cat.products.active.count %></td>
          <td>
            <div class="admin-actions">
              <%= link_to "Editar", edit_admin_category_path(cat), class: "btn-admin-ghost" %>
              <%= button_to "Eliminar", admin_category_path(cat),
                    method: :delete,
                    form: { data: { turbo_confirm: "¿Eliminar categoría #{cat.name}?" } },
                    class: "btn-admin-danger" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
