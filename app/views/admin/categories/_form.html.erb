<%= form_with model: [:admin, category], multipart: true, data: { controller: "direct-upload" } do |f| %>
  <div class="card">
    <div class="card-header"><h3 class="card-title">Datos de la categoría</h3></div>
    <div class="card-body">
      <% if category.errors.any? %>
        <div class="alert alert-danger mb-4">
          <ul class="mb-0">
            <% category.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <% if category.image.attached? %>
        <div class="mb-3">
          <%= image_tag category.image.variant(resize_to_limit: [ 300, 300 ]), style: "max-width:160px; border-radius:8px;" %>
        </div>
      <% end %>

      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :name, "Nombre", class: "form-label" %>
          <%= f.text_field :name, class: "form-control", placeholder: "Vestidos" %>
          <div class="form-text">El slug se genera automáticamente a partir del nombre.</div>
        </div>
        <div class="col-md-2">
          <%= f.label :position, "Posición", class: "form-label" %>
          <%= f.number_field :position, class: "form-control" %>
        </div>
        <div class="col-md-4">
          <%= f.label :image, "Imagen", class: "form-label" %>
          <%= f.file_field :image, class: "form-control", accept: "image/*", direct_upload: true,
                data: { direct_upload_target: "input" } %>
          <div class="progress mt-2" style="display:none; height:6px;" data-direct-upload-target="progressWrap">
            <div class="progress-bar" role="progressbar" style="width:0%" data-direct-upload-target="progressBar"></div>
          </div>
          <div class="form-text" data-direct-upload-target="status">
            <%= category.image.attached? ? "Dejar vacío para mantener la imagen actual." : "" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-3">
    <%= f.submit category.new_record? ? "Crear categoría" : "Guardar cambios", class: "btn btn-naar",
          data: { direct_upload_target: "submit" } %>
    <%= link_to "Cancelar", admin_categories_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
