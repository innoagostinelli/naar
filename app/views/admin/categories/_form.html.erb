<%= form_with model: [:admin, category], class: "admin-form" do |f| %>
  <% if category.errors.any? %>
    <div class="alert alert-danger mb-3">
      <ul class="mb-0">
        <% category.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :name, "Nombre", class: "form-label" %>
      <%= f.text_field :name, class: "form-control", placeholder: "Vestidos" %>
      <div class="form-hint">El slug se genera automáticamente a partir del nombre</div>
    </div>
    <div class="col-md-2">
      <%= f.label :position, "Posición", class: "form-label" %>
      <%= f.number_field :position, class: "form-control" %>
    </div>
  </div>

  <div class="mt-4 d-flex gap-2">
    <%= f.submit category.new_record? ? "Crear categoría" : "Guardar cambios", class: "btn-admin-primary" %>
    <%= link_to "Cancelar", admin_categories_path, class: "btn-admin-ghost" %>
  </div>
<% end %>
