<% content_for :page_title, "FAQs" %>
<% content_for :topbar_actions do %>
  <%= link_to "Nueva FAQ", new_admin_faq_path, class: "btn-admin-primary" %>
<% end %>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Pos.</th>
        <th>Pregunta</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @faqs.each do |faq| %>
        <tr>
          <td><%= faq.position %></td>
          <td><%= faq.question %></td>
          <td>
            <div class="admin-actions">
              <%= link_to "Editar", edit_admin_faq_path(faq), class: "btn-admin-ghost" %>
              <%= button_to "Eliminar", admin_faq_path(faq),
                    method: :delete,
                    form: { data: { turbo_confirm: "¿Eliminar esta FAQ?" } },
                    class: "btn-admin-danger" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
