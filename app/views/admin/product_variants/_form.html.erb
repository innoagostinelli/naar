<%= form_with model: [:admin, product, variant], class: "admin-form" do |f| %>
  <% if variant.errors.any? %>
    <div class="alert alert-danger mb-3">
      <ul class="mb-0">
        <% variant.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-3">
      <%= f.label :size, "Talla", class: "form-label" %>
      <%= f.select :size, %w[XS S M L XL Único], { prompt: "Seleccionar..." }, { class: "form-select" } %>
    </div>
    <div class="col-md-3">
      <%= f.label :color_name, "Nombre del color", class: "form-label" %>
      <%= f.text_field :color_name, class: "form-control", placeholder: "Negro" %>
    </div>
    <div class="col-md-2">
      <%= f.label :color_hex, "Color hex", class: "form-label" %>
      <div class="d-flex gap-2 align-items-center">
        <%= f.color_field :color_hex, class: "form-control form-control-color" %>
        <%= f.text_field :color_hex, class: "form-control", placeholder: "#211218",
              id: "color_hex_text", style: "flex:1;" %>
      </div>
    </div>
    <div class="col-md-2">
      <%= f.label :sku, "SKU", class: "form-label" %>
      <%= f.text_field :sku, class: "form-control", placeholder: "Opcional" %>
    </div>
    <div class="col-md-2">
      <%= f.label :stock, "Stock", class: "form-label" %>
      <%= f.number_field :stock, class: "form-control" %>
      <div class="form-hint">Vacío = sin control</div>
    </div>
  </div>

  <div class="mt-4 d-flex gap-2">
    <%= f.submit variant.new_record? ? "Agregar variante" : "Guardar cambios",
          class: "btn-admin-primary" %>
    <%= link_to "Cancelar", edit_admin_product_path(product), class: "btn-admin-ghost" %>
  </div>
<% end %>
