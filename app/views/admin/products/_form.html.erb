<%= form_with model: [:admin, product], class: "admin-form" do |f| %>
  <% if product.errors.any? %>
    <div class="alert alert-danger mb-3">
      <ul class="mb-0">
        <% product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-8">
      <%= f.label :name, "Nombre", class: "form-label" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :category_id, "Categoría", class: "form-label" %>
      <%= f.collection_select :category_id, Category.order(:position), :id, :name,
            { prompt: "Seleccionar..." }, { class: "form-select" } %>
    </div>

    <div class="col-12">
      <%= f.label :description, "Descripción", class: "form-label" %>
      <%= f.text_area :description, rows: 3, class: "form-control" %>
    </div>

    <div class="col-md-3">
      <%= f.label :price, "Precio ($)", class: "form-label" %>
      <%= f.number_field :price, step: "0.01", class: "form-control" %>
    </div>
    <div class="col-md-3">
      <%= f.label :compare_at_price, "Precio anterior ($)", class: "form-label" %>
      <%= f.number_field :compare_at_price, step: "0.01", class: "form-control" %>
      <div class="form-hint">Dejar vacío si no hay descuento</div>
    </div>
    <div class="col-md-3">
      <%= f.label :flag, "Flag", class: "form-label" %>
      <%= f.select :flag, Product.flags.keys.map { |k| [k.humanize, k] },
            {}, { class: "form-select" } %>
    </div>
    <div class="col-md-3">
      <%= f.label :status, "Estado", class: "form-label" %>
      <%= f.select :status, Product.statuses.keys.map { |k| [k.humanize, k] },
            {}, { class: "form-select" } %>
    </div>

    <div class="col-md-2">
      <%= f.label :position, "Posición", class: "form-label" %>
      <%= f.number_field :position, class: "form-control" %>
    </div>
  </div>

  <div class="mt-4 d-flex gap-2">
    <%= f.submit product.new_record? ? "Crear producto" : "Guardar cambios",
          class: "btn-admin-primary" %>
    <%= link_to "Cancelar", admin_products_path, class: "btn-admin-ghost" %>
  </div>
<% end %>
