<%= form_with model: [:admin, product] do |f| %>
  <div class="card mb-4">
    <div class="card-header"><h3 class="card-title">Información básica</h3></div>
    <div class="card-body">
      <% if product.errors.any? %>
        <div class="alert alert-danger mb-4">
          <ul class="mb-0">
            <% product.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <div class="row g-3">
        <div class="col-md-8">
          <%= f.label :name, "Nombre", class: "form-label" %>
          <%= f.text_field :name, class: "form-control", placeholder: "Vestido midi Sol" %>
        </div>
        <div class="col-md-4">
          <%= f.label :category_id, "Categoría", class: "form-label" %>
          <%= f.collection_select :category_id, Category.order(:position), :id, :name,
                { prompt: "Seleccionar..." }, { class: "form-select" } %>
        </div>
        <div class="col-12">
          <%= f.label :description, "Descripción", class: "form-label" %>
          <%= f.text_area :description, rows: 3, class: "form-control",
                placeholder: "Describí la prenda en pocas palabras..." %>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h3 class="card-title">Precios y configuración</h3></div>
    <div class="card-body">
      <div class="row g-3" data-controller="product-flag-sync">
        <div class="col-md-3">
          <%= f.label :price, "Precio ($)", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :price, step: "0.01", class: "form-control", placeholder: "55.00" %>
          </div>
        </div>
        <div class="col-md-3">
          <%= f.label :compare_at_price, "Precio anterior ($)", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :compare_at_price, step: "0.01", class: "form-control", placeholder: "—",
                  data: { product_flag_sync_target: "compareAtPrice", action: "input->product-flag-sync#sync" } %>
          </div>
          <div class="form-text">Dejar vacío si no hay descuento</div>
        </div>
        <div class="col-md-2">
          <%= f.label :flag, "Etiqueta", class: "form-label" %>
          <%= f.select :flag, Product.flags.keys.map { |k| [k.humanize, k] },
                {}, { class: "form-select", data: { product_flag_sync_target: "flag" } } %>
        </div>
        <div class="col-md-2">
          <%= f.label :status, "Estado", class: "form-label" %>
          <%= f.select :status, Product.statuses.keys.map { |k| [k.humanize, k] },
                {}, { class: "form-select" } %>
        </div>
        <div class="col-md-2">
          <%= f.label :position, "Posición", class: "form-label" %>
          <%= f.number_field :position, class: "form-control" %>
          <div class="form-text">Orden en la grilla</div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit product.new_record? ? "Crear producto" : "Guardar cambios",
          class: "btn btn-naar" %>
    <%= link_to "Cancelar", admin_products_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
