<% content_for :page_title, @product.name %>
<% content_for :topbar_actions do %>
  <%= link_to new_admin_product_path, class: "btn btn-outline-secondary btn-sm" do %>
    + Nuevo producto
  <% end %>
<% end %>

<%= render "form", product: @product %>

<div class="card mt-2">
  <div class="card-header d-flex align-items-center justify-content-between">
    <h3 class="card-title">Variantes <span class="text-muted fw-normal fs-6">(<%= @product.variants.count %>)</span></h3>
    <%= link_to new_admin_product_variant_path(@product), class: "btn btn-sm btn-naar" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Agregar variante
    <% end %>
  </div>

  <% if @product.variants.any? %>
    <div class="table-responsive">
      <table class="table table-vcenter table-hover card-table">
        <thead>
          <tr>
            <th>Color</th>
            <th>Talla</th>
            <th>SKU</th>
            <th>Stock</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @product.variants.order(:color_name, :size).each do |v| %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <span class="color-dot" style="background:<%= v.color_hex %>;"></span>
                  <div>
                    <div class="fw-semibold"><%= v.color_name %></div>
                    <div class="text-muted" style="font-size:.74rem;"><%= v.color_hex %></div>
                  </div>
                </div>
              </td>
              <td><span class="badge bg-light text-dark"><%= v.size %></span></td>
              <td class="text-muted"><%= v.sku.presence || "—" %></td>
              <td>
                <% if v.stock.nil? %>
                  <span class="text-muted">Sin control</span>
                <% elsif v.stock == 0 %>
                  <span class="text-danger fw-semibold">Agotado</span>
                <% else %>
                  <%= v.stock %>
                <% end %>
              </td>
              <td>
                <div class="admin-actions justify-content-end">
                  <%= link_to "Editar", edit_admin_product_variant_path(@product, v), class: "btn btn-sm btn-ghost" %>
                  <%= button_to "Eliminar", admin_product_variant_path(@product, v),
                        method: :delete,
                        form: { data: { turbo_confirm: "¿Eliminar variante #{v.display_name}?" } },
                        class: "btn btn-sm btn-danger-ghost" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card-body text-center text-muted py-5">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-2 opacity-50"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <p class="mb-3">Este producto no tiene variantes aún.</p>
      <%= link_to "+ Agregar primera variante", new_admin_product_variant_path(@product), class: "btn btn-naar btn-sm" %>
    </div>
  <% end %>
</div>
