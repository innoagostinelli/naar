<% content_for :page_title, "Dashboard" %>
<% content_for :topbar_actions do %>
  <%= link_to "Nuevo producto", new_admin_product_path, class: "btn-admin-primary" %>
<% end %>

<div class="admin-stat-grid">
  <div class="admin-stat">
    <div class="stat-num"><%= @total_products %></div>
    <div class="stat-label">Productos totales</div>
  </div>
  <div class="admin-stat">
    <div class="stat-num"><%= @active_products %></div>
    <div class="stat-label">Activos</div>
  </div>
  <div class="admin-stat">
    <div class="stat-num"><%= @oferta_products %></div>
    <div class="stat-label">En oferta</div>
  </div>
  <div class="admin-stat">
    <div class="stat-num"><%= @total_cats %></div>
    <div class="stat-label">Categorías</div>
  </div>
  <div class="admin-stat">
    <div class="stat-num"><%= @total_faqs %></div>
    <div class="stat-label">FAQs</div>
  </div>
  <div class="admin-stat">
    <div class="stat-num"><%= @total_reels %></div>
    <div class="stat-label">Reels</div>
  </div>
</div>

<div class="admin-card">
  <h2>Accesos rápidos</h2>
  <div class="d-flex gap-3 flex-wrap">
    <%= link_to "Ver productos", admin_products_path, class: "btn-admin-ghost" %>
    <%= link_to "Nueva categoría", new_admin_category_path, class: "btn-admin-ghost" %>
    <%= link_to "Nueva FAQ", new_admin_faq_path, class: "btn-admin-ghost" %>
    <%= link_to "Nuevo reel", new_admin_reel_path, class: "btn-admin-ghost" %>
  </div>
</div>
