<div class="product-card">
  <div class="product-media" style="background:<%= product[:bg] || '#FDF9DA' %>;">
    <% if product[:flag].present? %>
      <span class="product-flag <%= 'flag-oferta' if product[:flag] == 'OFERTA' %><%= ' flag-bestseller' if product[:flag] == 'BESTSELLER' %>">
        <%= product[:flag] %>
      </span>
    <% end %>
    <button class="product-fav" aria-label="Agregar a favoritos" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>
  </div>
  <div class="product-body">
    <h3 class="product-name"><%= product[:name] %></h3>
    <div class="product-meta">
      <div class="product-price">
        <%= product[:price] %>
        <% if product[:old].present? %><small><%= product[:old] %></small><% end %>
      </div>
      <button class="add-btn" aria-label="Agregar al carrito" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14"/>
        </svg>
      </button>
    </div>
    <% if product[:swatches].present? %>
      <div class="product-swatches">
        <% product[:swatches].each do |color| %>
          <span class="swatch" style="background:<%= color %>;"></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
